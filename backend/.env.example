PORT=3001
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# 32-byte hex string used to encrypt admin secrets stored in Firestore.
# Generate with: openssl rand -hex 32
MASTER_ENCRYPTION_KEY=

# Secret used to sign short-lived PIN-verification tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=
